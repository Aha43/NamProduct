---
// A standard page section: vertical rhythm + centered container, with an optional
// eyebrow/title/lead header block.
interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  lead?: string;
  class?: string;
}
const { id, eyebrow, title, lead, class: className } = Astro.props;
---

<section id={id} class={`py-20 sm:py-28 ${className ?? ''}`}>
  <div class="container">
    {(eyebrow || title || lead) && (
      <div class="mx-auto mb-14 max-w-2xl text-center">
        {eyebrow && (
          <p class="mb-3 text-xs font-semibold uppercase tracking-[0.25em] text-brand">{eyebrow}</p>
        )}
        {title && (
          <h2 class="text-balance text-3xl font-bold tracking-tight text-foreground sm:text-4xl">{title}</h2>
        )}
        {lead && <p class="mt-4 text-pretty text-lg text-muted-foreground">{lead}</p>}
      </div>
    )}
    <slot />
  </div>
</section>
