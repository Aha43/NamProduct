---
// A "detail": a panel that hovers over the page to explain one aspect of Nam in depth.
// Opened on demand from a feature card; advanced by hand (no autoplay). Each slide is a
// caption on top, a screenshot in the middle, and a short description at the bottom.
//
// A detail can hold MORE THAN ONE slideshow ("ways") when there's more than one way to do a
// thing in the app — e.g. processing the inbox one item at a time vs. in bulk. Pass `ways`
// (a labelled track each); a tab picker switches between them. For the common single-slideshow
// case, pass `slides` instead. Each slideshow has Back / dots / Next, a "Start over" restart,
// and a "Full screen" lightbox toggle; Esc (or the toggle, or clicking the image) steps out of
// full screen before closing.
//
// Open from anywhere with a trigger: <button data-detail-open="inbox">…</button>, where "inbox"
// matches this component's `id`. Image `src` paths should already include the site base.
export interface DetailSlide {
  caption: string;
  src: string;
  alt: string;
  description: string;
}
export interface DetailWay {
  /** Tab label, e.g. "One at a time". */
  label: string;
  slides: DetailSlide[];
}

interface Props {
  id: string;
  title: string;
  subtitle?: string;
  /** A single slideshow. */
  slides?: DetailSlide[];
  /** Two or more labelled slideshows (shows a tab picker). Takes precedence over `slides`. */
  ways?: DetailWay[];
}

const { id, title, subtitle, slides, ways } = Astro.props;
const tracks: DetailWay[] = ways && ways.length ? ways : [{ label: '', slides: slides ?? [] }];
const multiWay = tracks.length > 1;
const firstHasNav = (tracks[0]?.slides.length ?? 0) > 1;
---

<dialog
  id={`detail-${id}`}
  data-detail-overlay
  data-expanded="false"
  aria-label={title}
  class="detail-dialog group m-auto w-[min(56rem,calc(100vw-2rem))] rounded-2xl border border-border bg-card p-0 text-card-foreground shadow-2xl backdrop:bg-background/70 backdrop:backdrop-blur-sm data-[expanded=true]:h-screen data-[expanded=true]:max-h-none data-[expanded=true]:w-screen data-[expanded=true]:max-w-none data-[expanded=true]:rounded-none data-[expanded=true]:border-0"
>
  <div class="flex max-h-[calc(100vh-4rem)] flex-col group-data-[expanded=true]:relative group-data-[expanded=true]:h-full group-data-[expanded=true]:max-h-none group-data-[expanded=true]:overflow-hidden">
    <header class="flex items-start justify-between gap-3 border-b border-border/60 px-6 py-4 sm:px-8 group-data-[expanded=true]:absolute group-data-[expanded=true]:right-2 group-data-[expanded=true]:top-2 group-data-[expanded=true]:z-20 group-data-[expanded=true]:rounded-full group-data-[expanded=true]:border-0 group-data-[expanded=true]:bg-background/70 group-data-[expanded=true]:p-1 group-data-[expanded=true]:backdrop-blur">
      <div class="group-data-[expanded=true]:hidden">
        <h2 class="text-lg font-semibold tracking-tight text-foreground">{title}</h2>
        {subtitle && <p class="mt-0.5 text-sm text-muted-foreground">{subtitle}</p>}
      </div>
      <div class="flex shrink-0 items-center gap-1">
        <button
          type="button"
          data-detail-toggle-expand
          aria-label="Full screen"
          class="-mt-0.5 inline-flex h-9 items-center gap-1.5 rounded-md px-2.5 text-sm font-medium text-muted-foreground transition-colors hover:bg-muted/40 hover:text-foreground"
        >
          <svg data-icon-expand xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3"/><path d="M21 8V5a2 2 0 0 0-2-2h-3"/><path d="M3 16v3a2 2 0 0 0 2 2h3"/><path d="M16 21h3a2 2 0 0 0 2-2v-3"/></svg>
          <svg data-icon-collapse class="hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3v3a2 2 0 0 1-2 2H3"/><path d="M21 8h-3a2 2 0 0 1-2-2V3"/><path d="M3 16h3a2 2 0 0 1 2 2v3"/><path d="M16 21v-3a2 2 0 0 1 2-2h3"/></svg>
          <span class="hidden sm:inline" data-expand-label>Full screen</span>
        </button>
        <button
          type="button"
          data-detail-close
          aria-label="Close"
          class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-muted/40 hover:text-foreground"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12" /></svg>
        </button>
      </div>
    </header>

    {multiWay && (
      <div
        data-detail-ways
        role="tablist"
        aria-label="Ways to do this"
        class="flex flex-wrap items-center justify-center gap-1.5 border-b border-border/60 px-6 py-3 sm:px-8 group-data-[expanded=true]:hidden"
      >
        {tracks.map((track, ti) => (
          <button
            type="button"
            data-detail-way={ti}
            data-active={ti === 0 ? 'true' : 'false'}
            class="rounded-full border border-border px-3.5 py-1.5 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground data-[active=true]:border-brand/40 data-[active=true]:bg-brand/10 data-[active=true]:text-brand"
          >
            {track.label}
          </button>
        ))}
      </div>
    )}

    <div class="overflow-y-auto px-6 py-6 sm:px-8 group-data-[expanded=true]:absolute group-data-[expanded=true]:inset-0 group-data-[expanded=true]:flex group-data-[expanded=true]:items-center group-data-[expanded=true]:justify-center group-data-[expanded=true]:overflow-hidden group-data-[expanded=true]:p-0">
      {tracks.map((track, ti) =>
        track.slides.map((slide, si) => (
          <figure
            data-detail-track={ti}
            data-detail-slide={si}
            class={`flex flex-col group-data-[expanded=true]:relative group-data-[expanded=true]:h-full group-data-[expanded=true]:w-full ${ti === 0 && si === 0 ? '' : 'hidden'}`}
          >
            <figcaption class="text-center text-sm font-semibold uppercase tracking-[0.2em] text-brand group-data-[expanded=true]:absolute group-data-[expanded=true]:left-1/2 group-data-[expanded=true]:top-4 group-data-[expanded=true]:z-10 group-data-[expanded=true]:-translate-x-1/2 group-data-[expanded=true]:rounded-full group-data-[expanded=true]:bg-background/70 group-data-[expanded=true]:px-3.5 group-data-[expanded=true]:py-1 group-data-[expanded=true]:backdrop-blur">
              {slide.caption}
            </figcaption>
            <div
              data-detail-zoom
              title="Toggle full screen"
              class="mt-4 cursor-zoom-in overflow-hidden rounded-xl border border-border bg-background group-data-[expanded=true]:absolute group-data-[expanded=true]:inset-0 group-data-[expanded=true]:mt-0 group-data-[expanded=true]:flex group-data-[expanded=true]:cursor-zoom-out group-data-[expanded=true]:items-center group-data-[expanded=true]:justify-center group-data-[expanded=true]:rounded-none group-data-[expanded=true]:border-0 group-data-[expanded=true]:bg-transparent group-data-[expanded=true]:p-2"
            >
              <img src={slide.src} alt={slide.alt} loading="lazy" class="block w-full group-data-[expanded=true]:h-auto group-data-[expanded=true]:max-h-[calc(100vh-1rem)] group-data-[expanded=true]:w-auto group-data-[expanded=true]:max-w-full group-data-[expanded=true]:object-contain" />
            </div>
            <p class="mx-auto mt-4 max-w-2xl text-pretty text-center leading-relaxed text-muted-foreground group-data-[expanded=true]:absolute group-data-[expanded=true]:bottom-16 group-data-[expanded=true]:left-1/2 group-data-[expanded=true]:z-10 group-data-[expanded=true]:mt-0 group-data-[expanded=true]:max-w-xl group-data-[expanded=true]:-translate-x-1/2 group-data-[expanded=true]:rounded-lg group-data-[expanded=true]:bg-background/70 group-data-[expanded=true]:px-4 group-data-[expanded=true]:py-2 group-data-[expanded=true]:backdrop-blur">
              {slide.description}
            </p>
          </figure>
        )),
      )}
    </div>

    <footer
      data-detail-footer
      class={`items-center justify-between gap-4 border-t border-border/60 px-6 py-4 sm:px-8 group-data-[expanded=true]:absolute group-data-[expanded=true]:bottom-3 group-data-[expanded=true]:left-1/2 group-data-[expanded=true]:z-20 group-data-[expanded=true]:w-auto group-data-[expanded=true]:-translate-x-1/2 group-data-[expanded=true]:justify-center group-data-[expanded=true]:gap-4 group-data-[expanded=true]:rounded-full group-data-[expanded=true]:border-0 group-data-[expanded=true]:bg-background/70 group-data-[expanded=true]:px-3 group-data-[expanded=true]:py-2 group-data-[expanded=true]:backdrop-blur ${firstHasNav ? 'flex' : 'hidden'}`}
    >
      <button
        type="button"
        data-detail-prev
        class="inline-flex items-center gap-1.5 rounded-md border border-border bg-background px-3.5 py-1.5 text-sm font-medium text-foreground transition-colors hover:border-brand/50 disabled:cursor-not-allowed disabled:opacity-40"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
        Back
      </button>

      <div class="flex items-center gap-3">
        <div data-detail-dots class="flex items-center gap-2"></div>
        <button
          type="button"
          data-detail-restart
          aria-label="Start over"
          title="Start over"
          class="inline-flex h-7 w-7 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-muted/40 hover:text-foreground"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" /><path d="M3 3v5h5" /></svg>
        </button>
      </div>

      <button
        type="button"
        data-detail-next
        class="inline-flex items-center gap-1.5 rounded-md border border-border bg-background px-3.5 py-1.5 text-sm font-medium text-foreground transition-colors hover:border-brand/50 disabled:cursor-not-allowed disabled:opacity-40"
      >
        Next
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6" /></svg>
      </button>
    </footer>
  </div>
</dialog>

<script>
  // One global controller for every detail overlay. Idempotent guard keeps re-runs (HMR,
  // view transitions) from binding duplicate listeners.
  if (!(window as any).__detailOverlayInit) {
    (window as any).__detailOverlayInit = true;

    const figuresOf = (dialog: HTMLElement, track: number) =>
      dialog.querySelectorAll<HTMLElement>(`[data-detail-track="${track}"]`);

    // Rebuild the dot row to match the active track's slide count (tracks can differ in length).
    const buildDots = (dialog: HTMLElement, track: number) => {
      const wrap = dialog.querySelector<HTMLElement>('[data-detail-dots]');
      if (!wrap) return;
      const n = figuresOf(dialog, track).length;
      wrap.innerHTML = '';
      for (let i = 0; i < n; i++) {
        const dot = document.createElement('span');
        dot.dataset.detailDot = String(i);
        dot.className =
          'h-1.5 w-1.5 cursor-pointer rounded-full transition-colors ' +
          (i === 0 ? 'bg-brand' : 'bg-border hover:bg-foreground/40');
        wrap.appendChild(dot);
      }
    };

    // Show slide `index` within the active track.
    const showSlide = (dialog: HTMLElement, index: number) => {
      const track = Number(dialog.dataset.track ?? 0);
      const figs = figuresOf(dialog, track);
      if (!figs.length) return;
      const clamped = Math.max(0, Math.min(index, figs.length - 1));
      figs.forEach((f, i) => f.classList.toggle('hidden', i !== clamped));
      dialog.dataset.slide = String(clamped);

      dialog.querySelectorAll<HTMLElement>('[data-detail-dot]').forEach((dot, i) => {
        dot.classList.toggle('bg-brand', i === clamped);
        dot.classList.toggle('bg-border', i !== clamped);
      });

      const prev = dialog.querySelector<HTMLButtonElement>('[data-detail-prev]');
      const next = dialog.querySelector<HTMLButtonElement>('[data-detail-next]');
      if (prev) prev.disabled = clamped === 0;
      if (next) next.disabled = clamped === figs.length - 1;
    };

    // Switch to a different "way" (track) and start it from the beginning.
    const showTrack = (dialog: HTMLElement, track: number) => {
      dialog.querySelectorAll<HTMLElement>('[data-detail-track]').forEach((f) => f.classList.add('hidden'));
      dialog.dataset.track = String(track);
      dialog
        .querySelectorAll<HTMLElement>('[data-detail-way]')
        .forEach((w, i) => w.setAttribute('data-active', i === track ? 'true' : 'false'));
      buildDots(dialog, track);
      const footer = dialog.querySelector<HTMLElement>('[data-detail-footer]');
      if (footer) {
        const hasNav = figuresOf(dialog, track).length > 1;
        footer.classList.toggle('hidden', !hasNav);
        footer.classList.toggle('flex', hasNav);
      }
      showSlide(dialog, 0);
    };

    // Toggle the full-screen (expanded) state and keep the toggle button's icon + label in sync.
    const setExpanded = (dialog: HTMLElement, on: boolean) => {
      dialog.dataset.expanded = on ? 'true' : 'false';
      const btn = dialog.querySelector<HTMLElement>('[data-detail-toggle-expand]');
      if (!btn) return;
      btn.querySelector('[data-icon-expand]')?.classList.toggle('hidden', on);
      btn.querySelector('[data-icon-collapse]')?.classList.toggle('hidden', !on);
      const label = btn.querySelector('[data-expand-label]');
      if (label) label.textContent = on ? 'Exit full screen' : 'Full screen';
      btn.setAttribute('aria-label', on ? 'Exit full screen' : 'Full screen');
    };

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;

      const opener = target.closest<HTMLElement>('[data-detail-open]');
      if (opener) {
        e.preventDefault();
        const dialog = document.getElementById(`detail-${opener.dataset.detailOpen}`) as HTMLDialogElement | null;
        if (dialog) {
          setExpanded(dialog, false); // always open at normal size, first way, from the top
          showTrack(dialog, 0);
          dialog.showModal();
        }
        return;
      }

      const dialog = target.closest<HTMLDialogElement>('[data-detail-overlay]');
      if (!dialog) return;

      const way = target.closest<HTMLElement>('[data-detail-way]');
      const dot = target.closest<HTMLElement>('[data-detail-dot]');

      if (target.closest('[data-detail-close]')) {
        dialog.close();
      } else if (way) {
        showTrack(dialog, Number(way.dataset.detailWay ?? 0));
      } else if (target.closest('[data-detail-restart]')) {
        showSlide(dialog, 0);
      } else if (dot) {
        showSlide(dialog, Number(dot.dataset.detailDot ?? 0));
      } else if (target.closest('[data-detail-prev]')) {
        showSlide(dialog, Number(dialog.dataset.slide ?? 0) - 1);
      } else if (target.closest('[data-detail-next]')) {
        showSlide(dialog, Number(dialog.dataset.slide ?? 0) + 1);
      } else if (target.closest('[data-detail-toggle-expand]') || target.closest('[data-detail-zoom]')) {
        setExpanded(dialog, dialog.dataset.expanded !== 'true');
      } else if (target === dialog) {
        dialog.close(); // a click on the dialog element itself is the backdrop
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
      const dialog = document.querySelector<HTMLDialogElement>('[data-detail-overlay][open]');
      if (!dialog) return;
      showSlide(dialog, Number(dialog.dataset.slide ?? 0) + (e.key === 'ArrowRight' ? 1 : -1));
    });

    // Esc steps out of full screen first (one press), then closes the overlay (next press).
    document.querySelectorAll<HTMLElement>('[data-detail-overlay]').forEach((dialog) => {
      dialog.addEventListener('cancel', (e) => {
        if (dialog.dataset.expanded === 'true') {
          e.preventDefault();
          setExpanded(dialog, false);
        }
      });
    });
  }
</script>
