---
// An auto-advancing screenshot slideshow. Each slide is either a real image
// (`img`/`alt`) or, until those land, a captioned placeholder box. Styling is
// declarative (Tailwind `data-[active=true]:` variants); the small client script
// just toggles `data-active` and the caption, and handles auto-advance.
interface Slide {
  caption: string;
  desc?: string;
  img?: string;
  alt?: string;
}
interface Props {
  slides: Slide[];
  eyebrow?: string;
}
const { slides, eyebrow } = Astro.props;
const first = slides[0];
---

<div class="mx-auto max-w-4xl" data-screenshots>
  <!-- Header: the current slide's caption stands in for a section title (smaller than one). -->
  <div class="mb-8 text-center">
    {eyebrow && <p class="mb-2 text-xs font-semibold uppercase tracking-[0.25em] text-brand">{eyebrow}</p>}
    <p class="text-xl font-semibold tracking-tight text-foreground sm:text-2xl" data-caption-out>{first.caption}</p>
    <p class="mt-1 min-h-[1.5rem] text-sm text-muted-foreground" data-desc-out>{first.desc ?? ''}</p>
  </div>

  <div class="relative overflow-hidden rounded-xl border border-border bg-card shadow-sm">
    <div class="relative aspect-[16/10]">
      {slides.map((s, i) => (
        <figure
          class="absolute inset-0 opacity-0 transition-opacity duration-700 ease-out data-[active=true]:opacity-100"
          data-slide
          data-active={i === 0 ? 'true' : 'false'}
          data-caption={s.caption}
          data-desc={s.desc ?? ''}
          aria-hidden={i === 0 ? 'false' : 'true'}
        >
          {s.img ? (
            <img src={s.img} alt={s.alt ?? s.caption} class="h-full w-full object-cover object-top" loading={i === 0 ? 'eager' : 'lazy'} />
          ) : (
            <div class="flex h-full w-full flex-col items-center justify-center gap-3 bg-background/40 text-muted-foreground">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-50">
                <rect width="18" height="14" x="3" y="5" rx="2"/><path d="m3 15 4-4 5 5"/><path d="m14 14 2-2 5 5"/><circle cx="8.5" cy="9.5" r="1.5"/>
              </svg>
              <span class="text-sm font-medium">{s.caption}</span>
            </div>
          )}
        </figure>
      ))}
    </div>
  </div>

  <div class="mt-5 flex items-center justify-center gap-3">
      <button type="button" data-toggle aria-label="Pause slideshow" class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-border text-muted-foreground transition-colors hover:border-brand/50 hover:text-foreground">
        <svg data-icon-pause xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="5" width="4" height="14" rx="1"/><rect x="14" y="5" width="4" height="14" rx="1"/></svg>
        <svg data-icon-play class="hidden" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7 4 12 8-12 8z"/></svg>
      </button>
      <button type="button" data-prev aria-label="Previous screenshot" class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-border text-muted-foreground transition-colors hover:border-brand/50 hover:text-foreground">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <div class="flex items-center gap-2">
        {slides.map((_, i) => (
          <button type="button" data-dot data-active={i === 0 ? 'true' : 'false'} aria-label={`Show screenshot ${i + 1}`} class="h-2.5 w-2.5 rounded-full bg-foreground/20 transition-colors hover:bg-foreground/40 data-[active=true]:bg-brand"></button>
        ))}
      </div>
      <button type="button" data-next aria-label="Next screenshot" class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-border text-muted-foreground transition-colors hover:border-brand/50 hover:text-foreground">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>
  </div>
</div>

<script>
  const DELAY = 5000;

  function initShow(root: HTMLElement) {
    const slides = Array.from(root.querySelectorAll<HTMLElement>('[data-slide]'));
    const dots = Array.from(root.querySelectorAll<HTMLElement>('[data-dot]'));
    const capOut = root.querySelector<HTMLElement>('[data-caption-out]');
    const descOut = root.querySelector<HTMLElement>('[data-desc-out]');
    const toggleBtn = root.querySelector<HTMLElement>('[data-toggle]');
    const iconPause = root.querySelector<HTMLElement>('[data-icon-pause]');
    const iconPlay = root.querySelector<HTMLElement>('[data-icon-play]');
    if (slides.length === 0) return;

    // Honor reduced-motion by cutting the fade (instant swaps) rather than freezing
    // the slideshow — it still auto-plays, and the toggle below lets anyone pause it.
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) slides.forEach((s) => (s.style.transitionDuration = '0ms'));

    let idx = 0;
    let timer: number | undefined;
    let userPaused = false;

    function show(n: number) {
      idx = (n + slides.length) % slides.length;
      slides.forEach((s, i) => {
        const active = i === idx;
        s.dataset.active = active ? 'true' : 'false';
        s.setAttribute('aria-hidden', active ? 'false' : 'true');
      });
      dots.forEach((d, i) => (d.dataset.active = i === idx ? 'true' : 'false'));
      const cur = slides[idx];
      if (capOut) capOut.textContent = cur.dataset.caption || '';
      if (descOut) descOut.textContent = cur.dataset.desc || '';
    }

    function stopTimer() {
      if (timer !== undefined) {
        window.clearInterval(timer);
        timer = undefined;
      }
    }
    // Resume auto-advance unless the user explicitly paused it (hover/focus call this too).
    function startTimer() {
      if (userPaused) return;
      stopTimer();
      timer = window.setInterval(() => show(idx + 1), DELAY);
    }
    function updateToggle() {
      if (toggleBtn) toggleBtn.setAttribute('aria-label', userPaused ? 'Play slideshow' : 'Pause slideshow');
      iconPause?.classList.toggle('hidden', userPaused);
      iconPlay?.classList.toggle('hidden', !userPaused);
    }

    toggleBtn?.addEventListener('click', () => {
      userPaused = !userPaused;
      if (userPaused) stopTimer();
      else startTimer();
      updateToggle();
    });
    root.querySelector('[data-next]')?.addEventListener('click', () => { show(idx + 1); startTimer(); });
    root.querySelector('[data-prev]')?.addEventListener('click', () => { show(idx - 1); startTimer(); });
    dots.forEach((d, i) => d.addEventListener('click', () => { show(i); startTimer(); }));
    root.addEventListener('mouseenter', stopTimer);
    root.addEventListener('mouseleave', startTimer);
    root.addEventListener('focusin', stopTimer);
    root.addEventListener('focusout', startTimer);

    show(0);
    updateToggle();
    startTimer(); // auto-start on load for everyone
  }

  document.querySelectorAll<HTMLElement>('[data-screenshots]').forEach(initShow);
</script>
