---
// A borderless feature item: icon beside a title + description. When `detailId` is set,
// the card gains a "Learn more" trigger that opens the matching <DetailOverlay id={detailId}>.
interface Props {
  title: string;
  desc: string;
  detailId?: string;
}
const { title, desc, detailId } = Astro.props;
---

<div class="flex gap-4">
  <div class="mt-0.5 inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-md bg-brand/10 text-brand">
    <slot name="icon" />
  </div>
  <div>
    <h3 class="font-semibold text-foreground">{title}</h3>
    <p class="mt-1 text-sm leading-relaxed text-muted-foreground">{desc}</p>
    {detailId && (
      <button
        type="button"
        data-detail-open={detailId}
        class="group mt-2 inline-flex items-center gap-1 text-sm font-medium text-brand transition-colors hover:text-brand/80"
      >
        Learn more
        <span class="transition-transform group-hover:translate-x-0.5">→</span>
      </button>
    )}
  </div>
</div>
