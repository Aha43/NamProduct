---
import BaseLayout from '../layouts/BaseLayout.astro';
import Wordmark from '../components/Wordmark.astro';
import LogoMark from '../components/LogoMark.astro';
import Section from '../components/Section.astro';
import FeatureCard from '../components/FeatureCard.astro';
import Screenshots from '../components/Screenshots.astro';
import DetailOverlay from '../components/DetailOverlay.astro';
import type { DetailSlide } from '../components/DetailOverlay.astro';

// External links. TODO: real desktop download URL once releases are published.
const links = {
  desktopRepo: 'https://github.com/Aha43/NamDesktop',
  webRepo: 'https://github.com/Aha43/NamWeb',
  desktopReleases: 'https://github.com/Aha43/NamDesktop/releases',
  webApp: 'https://usenam.app', // login / sign-up (the auth screen also links to the demo)
  webDemo: 'https://usenam.app/demo', // straight into the no-account demo
};

const pillars = [
  {
    title: 'Use it anywhere',
    desc: 'Open Nam in any browser, from your phone to your laptop. Nothing to install — make an account and you are capturing in seconds, or try the demo first.',
  },
  {
    title: 'Stay focused',
    desc: 'Get everything out of your head, then let Nam surface the one thing worth doing right now. You stay clear; nothing gets lost.',
  },
  {
    title: 'Work with AI',
    desc: 'Use Claude or ChatGPT alongside Nam. Ask it to clear your inbox or rough out a project — it checks with you before changing anything.',
  },
];

const steps = [
  { n: '01', title: 'Capture', desc: 'Drop anything on your mind into the inbox. Do not sort it — just get it down.' },
  { n: '02', title: 'Sort', desc: 'Later, decide what each thing really is: a quick task, a bigger project, or nothing at all.' },
  { n: '03', title: 'Do', desc: 'Nam shows what is ready to act on right now. Pick one and go — the rest waits its turn.' },
];

// Screenshot slideshow — real shots of the live demo, captured at 16:10 (public/shots/).
// BASE_URL has no trailing slash here, so normalize before joining the asset path.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const screenshots = [
  { caption: 'Inbox', desc: 'Capture now, clarify later — everything lands in one place.', img: `${base}/shots/inbox.png`, alt: 'The Nam Inbox with captured items waiting to be clarified.' },
  { caption: 'Next', desc: 'A clear list of what is actually ready to do right now.', img: `${base}/shots/next.png`, alt: 'The Next view: actions ready to do, with project context, tags, and due dates.' },
  { caption: 'Projects', desc: 'Your work as a hierarchy, nested as deep as you need.', img: `${base}/shots/projects.png`, alt: 'The Projects list with several projects, each showing its tag and action count.' },
  { caption: 'An open project', desc: 'A focused workbench for one project and its actions.', img: `${base}/shots/project.png`, alt: 'An open project workbench showing its actions and a sub-project.' },
];

// "Details" — on-demand deep dives that open as a panel hovering over the page. The first,
// opened from the Inbox card, walks how you process an inbox item. Screenshots reuse the
// slideshow's public/shots/ set (scripts/shots.mjs); slide one is the inbox overview itself.
const inboxDetailSlides: DetailSlide[] = [
  {
    caption: 'Start with the inbox',
    src: `${base}/shots/inbox.png`,
    alt: 'The Nam inbox holding a handful of unsorted notes.',
    description:
      'Everything you captured lands here, unsorted. Processing the inbox just means going through it and deciding what each thing really is.',
  },
  {
    caption: 'Decide what it is',
    src: `${base}/shots/process-choose.png`,
    alt: 'The process dialog asking whether an item is a single action or needs planning.',
    description:
      'Pick up an item and Nam asks one question: is this a single action, or does it need planning? Two paths, no ceremony.',
  },
  {
    caption: 'A quick action',
    src: `${base}/shots/process-action.png`,
    alt: 'Turning an inbox item into an action to do next or park in the backlog.',
    description:
      'If it is one step, turn it into an action — do it next, or park it in the backlog for when the time is right.',
  },
  {
    caption: 'Something bigger',
    src: `${base}/shots/process-project.png`,
    alt: 'Turning an inbox item into a project.',
    description:
      'If it needs more than one step, make it a project. Now it has a home, and you can break it down whenever you like.',
  },
  {
    caption: 'Nothing to do',
    src: `${base}/shots/process-delete.png`,
    alt: 'Deleting an inbox item that no longer needs to exist.',
    description:
      'Not everything deserves to survive. If it is no longer worth doing, let it go — a clear inbox is the whole point.',
  },
];

const projectsDetailSlides: DetailSlide[] = [
  {
    caption: 'Group what belongs together',
    src: `${base}/shots/projects.png`,
    alt: 'The Projects list, each project showing its tag and how many actions are live.',
    description:
      'A project gathers related actions in one place. The list shows each one with its tag and how many actions are still live — so you can see where the work sits at a glance.',
  },
  {
    caption: 'A workbench for each one',
    src: `${base}/shots/project.png`,
    alt: 'An open project with its actions, a sub-project, and list / heat-map / column views.',
    description:
      'Open a project and you get a focused workbench — its actions, a place for notes, and sub-projects nested as deep as the work really goes. Look at it as a list, a heat-map, or columns.',
  },
];

const nextDetailSlides: DetailSlide[] = [
  {
    caption: 'Everything ready, in one list',
    src: `${base}/shots/next.png`,
    alt: 'The Next view: actions ready to do now, each with its project, tags, and due date.',
    description:
      'Nam pulls the actions that are genuinely ready — across every project — into one list, each with its project, tags, and any due date. You do not go hunting for what is next; it is already in front of you.',
  },
];

const tagsDetailSlides: DetailSlide[] = [
  {
    caption: 'Slice by context',
    src: `${base}/shots/tags.png`,
    alt: 'The Tags view filtered to one tag, pulling matching actions from across projects.',
    description:
      'Tag actions however you think — @phone, home, learn — then pick a tag to pull every matching action together, across all your projects at once.',
  },
  {
    caption: 'Save the views you live in',
    src: `${base}/shots/due.png`,
    alt: 'A standing view listing actions with deadlines.',
    description:
      'Found a slice you keep coming back to? Save it as a view. Nam also keeps standing views ready — like everything with a deadline, or the backlog waiting its turn.',
  },
];

const goalsDetailSlides: DetailSlide[] = [
  {
    caption: 'Your goals, at a glance',
    src: `${base}/shots/goals.png`,
    alt: 'A goal board grouping projects by tag, each showing how far along it is.',
    description:
      'Group projects by tag into a board — your Mission Control. Each one shows how far along it is, so in a single glance you can tell which goals are moving and which have quietly stalled.',
  },
];

const features: { title: string; desc: string; icon: string; detailId?: string }[] = [
  { title: 'Inbox', desc: 'Capture anything in a keystroke and decide what it is later.', icon: 'inbox', detailId: 'inbox' },
  { title: 'Projects', desc: 'Group related work and nest it as deep as you need.', icon: 'projects', detailId: 'projects' },
  { title: 'Next up', desc: 'A clear list of what is actually ready to do right now.', icon: 'next', detailId: 'next' },
  { title: 'Tags & views', desc: 'Slice your work by context and save the views you live in.', icon: 'tags', detailId: 'tags' },
  { title: 'Goal board', desc: 'See at a glance which projects are moving and which are stuck.', icon: 'goals', detailId: 'goals' },
  { title: 'Focus mode', desc: 'Work through a list one item at a time, with nothing else in the way.', icon: 'focus' },
];

// Imagined review — the kind of write-up Nam is built to earn, not real coverage.
// Swap in attributed quotes (outlet + article URL) if real press ever lands.
const pressHeadline = 'Your tasks do not need a bigger database. They need a better funnel.';
const pressCaption = 'The review we’d like to wake up to — imagined, for now.';
const pressQuotes = [
  'A rejection of a certain kind of productivity software: endlessly configurable systems that become impressive filing cabinets for work nobody actually does.',
  'At a time when many apps claim intelligence by promising to decide for users, Nam’s pitch is more restrained: it will not know your life better than you do.',
];

// Icon path data — the exact lucide icons NamWeb uses in its nav (src/shell/nav.ts), keyed by
// the `icon` field above: inbox→Inbox, projects→Folders, next→ListTodo, tags→Tag,
// goals→LayoutDashboard (Mission Control), focus→Target. Keep in sync with the web app.
const iconPaths: Record<string, string> = {
  inbox: '<polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>',
  projects: '<path d="M20 5a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h2.5a1.5 1.5 0 0 1 1.2.6l.6.8a1.5 1.5 0 0 0 1.2.6z"/><path d="M3 8.268a2 2 0 0 0-1 1.738V19a2 2 0 0 0 2 2h11a2 2 0 0 0 1.732-1"/>',
  next: '<path d="M13 5h8"/><path d="M13 12h8"/><path d="M13 19h8"/><path d="m3 17 2 2 4-4"/><rect x="3" y="4" width="6" height="6" rx="1"/>',
  tags: '<path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/>',
  goals: '<rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/>',
  focus: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
};
---

<BaseLayout>
  <!-- Header -->
  <header class="sticky top-0 z-50 border-b border-border/60 bg-background/80 backdrop-blur">
    <div class="container flex h-16 items-center justify-between">
      <Wordmark compact />
      <nav class="flex items-center gap-6 text-sm">
        <a href="#features" class="hidden text-muted-foreground transition-colors hover:text-foreground sm:inline">Features</a>
        <a href="#ai" class="hidden text-muted-foreground transition-colors hover:text-foreground sm:inline">AI</a>
        <a href="#press" class="hidden text-muted-foreground transition-colors hover:text-foreground sm:inline">Review</a>
        <a href="#desktop" class="hidden text-muted-foreground transition-colors hover:text-foreground sm:inline">Desktop</a>
        <a
          href={links.webDemo}
          class="rounded-md bg-primary px-3.5 py-1.5 font-medium text-primary-foreground transition-opacity hover:opacity-90"
        >
          Open app
        </a>
      </nav>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="hero-glow relative overflow-hidden">
      <div class="container py-16 text-center sm:py-24">
        <LogoMark class="mx-auto h-16 w-16 text-foreground" />
        <p class="mt-5 text-sm font-semibold uppercase tracking-[0.35em] text-muted-foreground">
          Next Action Master
        </p>
        <h1 class="mx-auto mt-4 max-w-3xl text-balance text-4xl font-semibold leading-tight tracking-tight text-foreground sm:text-5xl">
          Stay clear.<br /><span class="text-brand">Nothing gets lost.</span>
        </h1>
        <p class="mx-auto mt-6 max-w-xl text-pretty text-lg text-muted-foreground">
          Nam holds everything on your mind and shows you the one thing to do next. It runs
          in any browser, on any device — make an account and go, or try the demo first.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a
            href={links.webApp}
            class="inline-flex w-full items-center justify-center rounded-md bg-primary px-6 py-3 font-medium text-primary-foreground transition-opacity hover:opacity-90 sm:w-auto"
          >
            Open Nam in your browser
          </a>
          <a
            href={links.webDemo}
            class="inline-flex w-full items-center justify-center rounded-md border border-border bg-card px-6 py-3 font-medium text-card-foreground transition-colors hover:border-brand/50 sm:w-auto"
          >
            Try the demo — no account
          </a>
        </div>
        <p class="mt-5 text-sm text-muted-foreground">
          Free &amp; open source · Works in any browser · Desktop app for macOS &amp; Windows
        </p>
      </div>
    </section>

    <!-- Screenshot slideshow -->
    <Section>
      <Screenshots slides={screenshots} eyebrow="See it in action" />
    </Section>

    <!-- Three pillars -->
    <Section eyebrow="Why Nam" title="Built around three ideas" class="bg-card/30">
      <div class="grid gap-x-10 gap-y-8 md:grid-cols-3">
        {pillars.map((p) => (
          <div class="border-t border-brand/40 pt-5">
            <h3 class="text-lg font-semibold text-foreground">{p.title}</h3>
            <p class="mt-3 text-muted-foreground">{p.desc}</p>
          </div>
        ))}
      </div>
    </Section>

    <!-- How it works -->
    <Section
      eyebrow="How it works"
      title="Capture. Sort. Do."
      lead="No methodology to learn. Get things out of your head, and let Nam keep the next step in front of you. (If you know GTD, you will feel right at home.)"
    >
      <div class="grid gap-10 sm:grid-cols-3">
        {steps.map((s) => (
          <div>
            <span class="text-2xl font-bold tracking-tight text-brand/50">{s.n}</span>
            <h3 class="mt-2 text-lg font-semibold text-foreground">{s.title}</h3>
            <p class="mt-2 leading-relaxed text-muted-foreground">{s.desc}</p>
          </div>
        ))}
      </div>
    </Section>

    <!-- Feature grid -->
    <Section
      id="features"
      eyebrow="What's inside"
      title="Just enough structure"
      lead="One simple set of work you can look at in different ways — never more app than the job needs."
    >
      <div class="mx-auto grid max-w-4xl gap-x-10 gap-y-7 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f) => (
          <FeatureCard title={f.title} desc={f.desc} detailId={f.detailId}>
            <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[f.icon]} />
          </FeatureCard>
        ))}
      </div>
    </Section>

    <!-- Detail overlays: panels that hover over the page for an on-demand deep dive. -->
    <DetailOverlay
      id="inbox"
      title="Ways to process an inbox"
      subtitle="Go through what you captured and decide what each thing really is."
      slides={inboxDetailSlides}
    />
    <DetailOverlay
      id="projects"
      title="Projects, nested as deep as you like"
      subtitle="Group related work, then open it up into a focused workbench."
      slides={projectsDetailSlides}
    />
    <DetailOverlay
      id="next"
      title="The one list of what is ready"
      subtitle="No digging, no deciding what is next — Nam keeps it in front of you."
      slides={nextDetailSlides}
    />
    <DetailOverlay
      id="tags"
      title="Tags &amp; views"
      subtitle="Slice your work by context, and keep the views you live in."
      slides={tagsDetailSlides}
    />
    <DetailOverlay
      id="goals"
      title="A board for your goals"
      subtitle="Group projects into Mission Control — see what is moving, and what is stuck."
      slides={goalsDetailSlides}
    />

    <!-- AI-native -->
    <Section id="ai">
      <div class="mx-auto grid max-w-4xl items-center gap-10 rounded-2xl border border-border bg-card p-7 md:grid-cols-2 sm:p-10">
        <div>
          <p class="mb-3 text-xs font-semibold uppercase tracking-[0.25em] text-brand">AI-native</p>
          <h2 class="text-3xl font-bold tracking-tight text-card-foreground">Hand the busywork to your AI</h2>
          <p class="mt-4 text-muted-foreground">
            Use Claude or ChatGPT right alongside Nam. Ask it to sort your inbox, sketch out a
            project, or tidy things up — and it checks with you before every change. Nothing
            touches your workspace without your okay.
          </p>
          <a href={links.webRepo} class="mt-6 inline-flex items-center gap-1.5 font-medium text-brand hover:underline">
            See how it works →
          </a>
        </div>
        <div class="rounded-xl border border-border bg-background p-5 font-mono text-sm text-muted-foreground">
          <div class="flex items-center gap-1.5 pb-3">
            <span class="h-2.5 w-2.5 rounded-full bg-destructive/60"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-brand/60"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-primary/60"></span>
          </div>
          <p><span class="text-brand">you ›</span> sort my inbox into projects</p>
          <p class="mt-2 text-foreground">Claude proposed 6 changes:</p>
          <p class="mt-1">+ project “Q3 launch”</p>
          <p>+ 4 tasks tagged <span class="text-brand">@computer</span></p>
          <p>↳ moved 1 item to later</p>
          <p class="mt-2"><span class="text-foreground">[ accept ]</span> [ reject ]</p>
        </div>
      </div>
    </Section>

    <!-- Imagined review (not real coverage — see index data above) -->
    <Section id="press" eyebrow="An imagined review" class="bg-card/30">
      <figure class="mx-auto max-w-3xl text-center">
        <blockquote class="text-balance text-2xl font-semibold leading-snug tracking-tight text-foreground sm:text-3xl">
          &ldquo;{pressHeadline}&rdquo;
        </blockquote>
        <figcaption class="mt-6 text-sm text-muted-foreground">
          {pressCaption}
        </figcaption>
      </figure>
      <div class="mx-auto mt-10 grid max-w-4xl gap-x-10 gap-y-8 sm:grid-cols-2">
        {pressQuotes.map((q) => (
          <blockquote class="border-t border-brand/40 pt-5">
            <p class="text-pretty leading-relaxed text-foreground/90">&ldquo;{q}&rdquo;</p>
          </blockquote>
        ))}
      </div>
    </Section>

    <!-- Desktop (the niche option) -->
    <Section id="desktop" class="bg-card/30">
      <div class="mx-auto max-w-2xl">
        <p class="mb-3 text-xs font-semibold uppercase tracking-[0.25em] text-brand">For power users &amp; purists</p>
        <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
          Want it all on your own machine?
        </h2>
        <p class="mt-4 text-lg text-muted-foreground">
          Most people never need to leave the browser. But if you want more room to work — or
          you would rather your tasks never touch a server — there is a full desktop app.
          <strong class="font-semibold text-foreground">NamDesktop</strong> is its own thing,
          for two kinds of people:
        </p>
        <ul class="mt-7 space-y-4">
          {[
            'Power users who live in Nam all day and want a roomier workbench — and who pair the desktop with the browser app so they can capture on their phone too.',
            'Old-school and privacy-minded folks who keep everything local: a single file on your own machine, with no cloud at all — or a simple Git sync you control.',
          ].map((item) => (
            <li class="flex gap-3 text-muted-foreground">
              <svg class="mt-1 h-5 w-5 shrink-0 text-brand" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7" /></svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <a href={links.desktopReleases} class="mt-8 inline-flex items-center gap-1.5 font-medium text-brand hover:underline">
          Get NamDesktop · macOS &amp; Windows →
        </a>
      </div>
    </Section>

    <!-- Final CTA -->
    <Section>
      <div class="mx-auto max-w-2xl text-center">
        <LogoMark class="mx-auto h-12 w-12 text-foreground" />
        <h2 class="mt-6 text-balance text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
          Get your head clear today
        </h2>
        <p class="mt-4 text-lg text-muted-foreground">
          Open Nam in your browser, get everything off your mind, and let the next step
          find you. Make an account and go — or try the demo first.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a
            href={links.webApp}
            class="inline-flex w-full items-center justify-center rounded-md bg-primary px-6 py-3 font-medium text-primary-foreground transition-opacity hover:opacity-90 sm:w-auto"
          >
            Open Nam in your browser
          </a>
          <a
            href="#desktop"
            class="inline-flex w-full items-center justify-center rounded-md border border-border bg-card px-6 py-3 font-medium text-card-foreground transition-colors hover:border-brand/50 sm:w-auto"
          >
            Or get the desktop app
          </a>
        </div>
      </div>
    </Section>
  </main>

  <!-- Footer -->
  <footer class="border-t border-border">
    <div class="container flex flex-col items-center justify-between gap-6 py-10 sm:flex-row">
      <Wordmark compact />
      <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-muted-foreground">
        <a href={links.desktopRepo} class="transition-colors hover:text-foreground">NamDesktop</a>
        <a href={links.webRepo} class="transition-colors hover:text-foreground">NamWeb</a>
        <a href="#features" class="transition-colors hover:text-foreground">Features</a>
        <a href={links.desktopReleases} class="transition-colors hover:text-foreground">Download</a>
      </nav>
      <p class="text-sm text-muted-foreground">© {new Date().getFullYear()} Nam</p>
    </div>
  </footer>
</BaseLayout>
