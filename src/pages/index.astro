---
import BaseLayout from '../layouts/BaseLayout.astro';
import Wordmark from '../components/Wordmark.astro';
import LogoMark from '../components/LogoMark.astro';
import Section from '../components/Section.astro';
import FeatureCard from '../components/FeatureCard.astro';

// External links. TODO: confirm/replace with real download + hosted URLs when available.
const links = {
  desktopRepo: 'https://github.com/Aha43/NamDesktop',
  webRepo: 'https://github.com/Aha43/NamWeb',
  desktopReleases: 'https://github.com/Aha43/NamDesktop/releases',
  webApp: 'https://github.com/Aha43/NamWeb', // TODO: hosted NamWeb URL once deployed
};

const pillars = [
  {
    title: 'Own your data',
    desc: 'Your work lives in a single JSON file on your machine. No account, no subscription, no mandatory cloud. Back it up, version it, move it — it is yours.',
  },
  {
    title: 'Stay focused',
    desc: 'Capture anything that has your attention, then let Next Actions show only what you can actually do right now. You stay clear; nothing gets lost.',
  },
  {
    title: 'Work with AI',
    desc: 'A built-in MCP server wires Nam to Claude. Ask it to triage your inbox, draft a project, or reshape your backlog — then accept or reject the changes.',
  },
];

const steps = [
  { n: '01', title: 'Capture', desc: 'Drop anything into the Inbox. Do not think, just capture — bulk-paste a whole list if you want.' },
  { n: '02', title: 'Process', desc: 'Decide what each thing is: a next action, a project, or nothing. Clear the inbox to zero.' },
  { n: '03', title: 'Work', desc: 'Filter by context and pick one next action. Focus mode walks you through them one at a time.' },
  { n: '04', title: 'Review', desc: 'A weekly pass keeps the tree honest. Goal Boards show, at a glance, what is ready and what is stuck.' },
];

const features = [
  { title: 'Inbox', desc: 'Frictionless capture you process later — never lose a thought.', icon: 'inbox' },
  { title: 'Projects', desc: 'Nest sub-projects to any depth. Structure without ceremony.', icon: 'tree' },
  { title: 'Next Actions', desc: 'Status-based, not structure-based — what you can do right now.', icon: 'bolt' },
  { title: 'Tags & Views', desc: 'Filter by @context and save named lenses over the same tree.', icon: 'tag' },
  { title: 'Goal Board', desc: 'Mission Control: projects grouped and color-coded by readiness.', icon: 'target' },
  { title: 'Templates', desc: 'Save a project shape once, clone it whenever you need it.', icon: 'copy' },
  { title: 'Blocked by', desc: 'Track dependencies; Done stays locked until blockers clear.', icon: 'lock' },
  { title: 'Focus mode', desc: 'Work a list one action at a time, with nothing else in the way.', icon: 'focus' },
];

// Stroke-based icon path data (Tabler/Lucide style), keyed by the `icon` field above.
const iconPaths: Record<string, string> = {
  inbox: '<path d="M4 13h4l2 3h4l2-3h4"/><path d="M5 13l1.5-6.5A2 2 0 0 1 8.4 5h7.2a2 2 0 0 1 1.9 1.5L19 13v4a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2z"/>',
  tree: '<circle cx="12" cy="5" r="2"/><circle cx="6" cy="19" r="2"/><circle cx="18" cy="19" r="2"/><path d="M12 7v3m0 0H7a1 1 0 0 0-1 1v6m6-7h5a1 1 0 0 1 1 1v6"/>',
  bolt: '<path d="M13 3 4 14h7l-1 7 9-11h-7z"/>',
  tag: '<path d="M7.5 7.5h.01"/><path d="M3 11V5a2 2 0 0 1 2-2h6l9 9-7 7-9-9z"/>',
  target: '<circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="4"/><circle cx="12" cy="12" r="0.5" fill="currentColor"/>',
  copy: '<rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2"/>',
  lock: '<rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/>',
  focus: '<circle cx="12" cy="12" r="3"/><path d="M3 7V5a2 2 0 0 1 2-2h2M17 3h2a2 2 0 0 1 2 2v2M21 17v2a2 2 0 0 1-2 2h-2M7 21H5a2 2 0 0 1-2-2v-2"/>',
};
---

<BaseLayout>
  <!-- Header -->
  <header class="sticky top-0 z-50 border-b border-border/60 bg-background/80 backdrop-blur">
    <div class="container flex h-16 items-center justify-between">
      <Wordmark compact />
      <nav class="flex items-center gap-6 text-sm">
        <a href="#suite" class="hidden text-muted-foreground transition-colors hover:text-foreground sm:inline">The suite</a>
        <a href="#features" class="hidden text-muted-foreground transition-colors hover:text-foreground sm:inline">Features</a>
        <a href="#ai" class="hidden text-muted-foreground transition-colors hover:text-foreground sm:inline">AI</a>
        <a
          href={links.desktopReleases}
          class="rounded-md bg-primary px-3.5 py-1.5 font-medium text-primary-foreground transition-opacity hover:opacity-90"
        >
          Download
        </a>
      </nav>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="hero-glow relative overflow-hidden">
      <div class="container py-24 text-center sm:py-32">
        <LogoMark class="mx-auto h-16 w-16 text-foreground" />
        <p class="mt-6 text-sm font-semibold uppercase tracking-[0.35em] text-muted-foreground">
          Next Action Master
        </p>
        <h1 class="mx-auto mt-5 max-w-3xl text-balance text-5xl font-bold tracking-tight text-foreground sm:text-6xl">
          Stay clear.<br /><span class="text-brand">Nothing gets lost.</span>
        </h1>
        <p class="mx-auto mt-6 max-w-xl text-pretty text-lg text-muted-foreground">
          A local-first, GTD-inspired way to capture, focus, and finish. Nam keeps your
          work on your machine — and in your pocket when you are away from it.
        </p>
        <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a
            href={links.desktopReleases}
            class="inline-flex w-full items-center justify-center rounded-md bg-primary px-6 py-3 font-medium text-primary-foreground transition-opacity hover:opacity-90 sm:w-auto"
          >
            Get NamDesktop
          </a>
          <a
            href={links.webApp}
            class="inline-flex w-full items-center justify-center rounded-md border border-border bg-card px-6 py-3 font-medium text-card-foreground transition-colors hover:border-brand/50 sm:w-auto"
          >
            Open NamWeb
          </a>
        </div>
        <p class="mt-5 text-sm text-muted-foreground">
          Free &amp; open source · macOS &amp; Windows · No account required
        </p>
      </div>
    </section>

    <!-- The suite -->
    <Section
      id="suite"
      eyebrow="One system, two surfaces"
      title="The Nam suite"
      lead="The same node tree, wherever you are. The desktop is your workbench; the web is the companion you reach for on the go."
    >
      <div class="mx-auto grid max-w-4xl gap-6 md:grid-cols-2">
        <div class="rounded-xl border border-border bg-card p-7">
          <span class="inline-flex items-center rounded-full bg-brand/10 px-2.5 py-1 text-xs font-medium text-brand">Primary app</span>
          <h3 class="mt-4 text-2xl font-bold text-card-foreground">NamDesktop</h3>
          <p class="mt-3 text-muted-foreground">
            The full workbench. Capture, organize nested projects, filter by context, run
            Goal Boards and templates — all local-first, with your data as a single JSON
            file. macOS &amp; Windows.
          </p>
          <a href={links.desktopRepo} class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-brand hover:underline">
            View on GitHub →
          </a>
        </div>
        <div class="rounded-xl border border-border bg-card p-7">
          <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-1 text-xs font-medium text-primary">Companion</span>
          <h3 class="mt-4 text-2xl font-bold text-card-foreground">NamWeb</h3>
          <p class="mt-3 text-muted-foreground">
            Fast capture and triage from any phone, tablet, or browser. Add a thought, see
            what is next, tick something done — always in sync with the desktop through the
            shared cloud backend.
          </p>
          <a href={links.webRepo} class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:underline">
            View on GitHub →
          </a>
        </div>
      </div>

      <!-- TODO: replace with real product screenshots (desktop Next Actions panel + NamWeb phone shell). -->
      <div class="mx-auto mt-10 flex aspect-[16/8] max-w-4xl items-center justify-center rounded-xl border border-dashed border-border bg-card/50 text-sm text-muted-foreground">
        Product screenshots go here
      </div>
    </Section>

    <!-- Three pillars -->
    <Section eyebrow="Why Nam" title="Built around three ideas" class="bg-card/30">
      <div class="grid gap-6 md:grid-cols-3">
        {pillars.map((p) => (
          <div class="rounded-xl border border-border bg-card p-7">
            <h3 class="text-lg font-semibold text-card-foreground">{p.title}</h3>
            <p class="mt-3 text-muted-foreground">{p.desc}</p>
          </div>
        ))}
      </div>
    </Section>

    <!-- How it works -->
    <Section
      eyebrow="The loop"
      title="Capture → Process → Work → Review"
      lead="A simple rhythm borrowed from GTD — accessible whether or not you have ever read the book."
    >
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {steps.map((s) => (
          <div class="relative rounded-xl border border-border bg-card p-6">
            <span class="text-3xl font-bold tracking-tight text-brand/40">{s.n}</span>
            <h3 class="mt-3 font-semibold text-card-foreground">{s.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{s.desc}</p>
          </div>
        ))}
      </div>
    </Section>

    <!-- Feature grid -->
    <Section
      id="features"
      eyebrow="Everything in the box"
      title="One tree, many lenses"
      lead="The same underlying nodes, interpreted by where they sit, their status, and which view is active."
      class="bg-card/30"
    >
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {features.map((f) => (
          <FeatureCard title={f.title} desc={f.desc}>
            <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[f.icon]} />
          </FeatureCard>
        ))}
      </div>
    </Section>

    <!-- AI-native -->
    <Section id="ai">
      <div class="mx-auto grid max-w-4xl items-center gap-10 rounded-2xl border border-border bg-card p-8 md:grid-cols-2 sm:p-12">
        <div>
          <p class="mb-3 text-xs font-semibold uppercase tracking-[0.25em] text-brand">AI-native</p>
          <h2 class="text-3xl font-bold tracking-tight text-card-foreground">Hand the busywork to Claude</h2>
          <p class="mt-4 text-muted-foreground">
            Nam ships with a built-in MCP server, so Claude can read your workspace and
            propose changes — triage the inbox, scaffold a project, reshape the backlog.
            You review every batch with a clear diff and accept or reject it. Your data
            never leaves your control.
          </p>
          <a href={links.desktopRepo} class="mt-6 inline-flex items-center gap-1.5 font-medium text-brand hover:underline">
            See how the integration works →
          </a>
        </div>
        <div class="rounded-xl border border-border bg-background p-5 font-mono text-sm text-muted-foreground">
          <div class="flex items-center gap-1.5 pb-3">
            <span class="h-2.5 w-2.5 rounded-full bg-destructive/60"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-brand/60"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-primary/60"></span>
          </div>
          <p><span class="text-brand">you ›</span> tidy my inbox into projects</p>
          <p class="mt-2 text-foreground">Claude proposed 6 changes:</p>
          <p class="mt-1">+ project “Q3 launch”</p>
          <p>+ 4 next actions tagged <span class="text-brand">@computer</span></p>
          <p>↳ moved 1 item to backlog</p>
          <p class="mt-2"><span class="text-foreground">[ accept ]</span> [ reject ]</p>
        </div>
      </div>
    </Section>

    <!-- Final CTA -->
    <Section>
      <div class="mx-auto max-w-2xl text-center">
        <LogoMark class="mx-auto h-12 w-12 text-foreground" />
        <h2 class="mt-6 text-balance text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
          Get your head clear today
        </h2>
        <p class="mt-4 text-lg text-muted-foreground">
          Download NamDesktop, capture everything on your mind, and let the next action
          find you.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a
            href={links.desktopReleases}
            class="inline-flex w-full items-center justify-center rounded-md bg-primary px-6 py-3 font-medium text-primary-foreground transition-opacity hover:opacity-90 sm:w-auto"
          >
            Download NamDesktop
          </a>
          <a
            href={links.desktopRepo}
            class="inline-flex w-full items-center justify-center rounded-md border border-border bg-card px-6 py-3 font-medium text-card-foreground transition-colors hover:border-brand/50 sm:w-auto"
          >
            Star on GitHub
          </a>
        </div>
      </div>
    </Section>
  </main>

  <!-- Footer -->
  <footer class="border-t border-border">
    <div class="container flex flex-col items-center justify-between gap-6 py-10 sm:flex-row">
      <Wordmark compact />
      <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-muted-foreground">
        <a href={links.desktopRepo} class="transition-colors hover:text-foreground">NamDesktop</a>
        <a href={links.webRepo} class="transition-colors hover:text-foreground">NamWeb</a>
        <a href="#features" class="transition-colors hover:text-foreground">Features</a>
        <a href={links.desktopReleases} class="transition-colors hover:text-foreground">Download</a>
      </nav>
      <p class="text-sm text-muted-foreground">© {new Date().getFullYear()} Nam</p>
    </div>
  </footer>
</BaseLayout>
